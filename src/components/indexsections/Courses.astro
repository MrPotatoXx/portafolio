---
import Section from "@/components/Section.astro";
import Certificate from "@/icons/Certificate.astro";
import Cisco from "@/icons/Cisco.astro";
import CertLinkedIn from "@/icons/CertLinkedIn.astro";
import GoogleCloud from "@/icons/GoogleCloud.astro";
import Udemy from "@/icons/Udemy.astro";
import { getTranslations, getCv } from "@/translations";

const currentLocale = Astro.currentLocale as 'es' | 'en' || 'es';
const t = getTranslations(currentLocale);
const cv = getCv(currentLocale);

const formatCertDate = (dateStr: string) => {
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return new Intl.DateTimeFormat(currentLocale, { year: 'numeric', month: 'short', timeZone: 'UTC' }).format(d);
};

const getIcon = (issuer: string) => {
  switch (issuer.toLowerCase()) {
    case 'cisco':
      return Cisco;
    case 'linkedin':
      return CertLinkedIn;
    case 'google':
      return GoogleCloud;
    case 'udemy':
      return Udemy;
    default:
      return Certificate;
  }
};

const visibleCerts = cv.certificates.filter(({ hidden }) => !hidden);
const mainCerts = visibleCerts.filter(({ collapsed }) => !collapsed);
const badgeCerts = visibleCerts.filter(({ collapsed }) => collapsed);

const badgeGroups = badgeCerts.reduce<Record<string, typeof badgeCerts>>((groups, cert) => {
  (groups[cert.issuer] ??= []).push(cert);
  return groups;
}, {});
---

<Section id={t.sectionIds.courses} title={t.sections.courses}>
  <div class="max-w-3xl mx-auto w-full bg-gradient-to-br from-slate-800/80 to-slate-900/80 rounded-2xl shadow-xl border-2 border-sky-900/30 p-4 md:p-6 mb-4">
    <ul class="flex flex-col gap-3">
      {
        mainCerts.map(({ name, date, issuer, url }) => {
          const Icon = getIcon(issuer);
          return (
            <li class="bg-gradient-to-br from-slate-800/80 to-slate-900/80 shadow-xl border border-sky-900/30 rounded-lg overflow-hidden transition-transform duration-200 hover:scale-[1.02] text-xs md:text-sm">
              <div class="flex items-center pl-2">
                <div class="p-4 bg-gradient-to-br from-sky-600/20 to-sky-800/20 flex items-center justify-center border-r border-sky-900/30 h-full min-w-[70px]">
                  <Icon class="w-6 h-6 text-sky-300" />
                </div>
                <div class="flex-grow p-3">
                  <h3 class="text-base text-sky-300 font-bold">{name}</h3>
                  <div class="flex flex-wrap gap-2 mt-2 items-center justify-between w-full">
                    <div class="flex flex-wrap gap-2">
                      <span class="inline-block px-2 py-1 bg-sky-600/20 text-sky-200 rounded-full text-xs font-semibold border border-sky-500/30">{issuer}</span>
                      <span class="inline-block px-2 py-1 bg-cyan-600/20 text-cyan-200 rounded-full text-xs font-semibold border border-cyan-500/30">{formatCertDate(date)}</span>
                    </div>
                    {url && (
                      <a
                        href={url}
                        class="inline-block ml-auto px-3 py-1 bg-gradient-to-r from-sky-400/20 to-cyan-400/20 text-sky-200 border border-sky-500/30 rounded-full text-xs font-medium hover:bg-sky-400/40 transition-all duration-200 shadow-sm"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
{t.projects.viewCertificate}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </li>
          );
        })
      }
      {
        Object.entries(badgeGroups).map(([issuer, certs]) => {
          const Icon = getIcon(issuer);
          return (
            <li class="rounded-lg border border-sky-900/30 overflow-hidden">
              <details class="group">
                <summary class="flex items-center gap-3 p-3 cursor-pointer bg-gradient-to-br from-slate-800/80 to-slate-900/80 hover:bg-sky-900/20 transition-colors list-none">
                  <Icon class="w-6 h-6 text-sky-300 flex-shrink-0" />
                  <span class="text-sm md:text-base text-sky-300 font-bold flex-grow">
                    {t.courses.showBadges.replace('{count}', String(certs.length)).replace('{issuer}', issuer)}
                  </span>
                  <span class="text-sky-400 transition-transform duration-200 group-open:rotate-180">▾</span>
                </summary>
                <ul class="flex flex-col divide-y divide-sky-900/30 bg-slate-900/60">
                  {certs.map(({ name, date, url }) => (
                    <li class="flex flex-wrap items-center gap-x-2 gap-y-1 px-4 py-2 text-xs md:text-sm">
                      <span class="text-gray-300">{name}</span>
                      <span class="text-cyan-300">{formatCertDate(date)}</span>
                      {url && (
                        <a
                          href={url}
                          class="ml-auto flex-shrink-0 text-sky-300 hover:text-cyan-300 underline underline-offset-2"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
{t.projects.viewCertificate}
                        </a>
                      )}
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>
